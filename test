-- AUTO PHASE (optimised with caching)
local canPhase = true
local autoPhaseConn = nil
local phaseableCache = {}
local lastCacheUpdate = 0
local function getCheckParts(mc)
	local m = mc:FindFirstChild("CheckParts")
	if not m then
		return nil
	end
	local ok, r = pcall(require, m)
	if not ok or type(r) ~= "table" then
		return nil
	end
	return r
end
local function updatePhaseableCache()
	local other = workspace.MAPS and workspace.MAPS:FindFirstChild("GAME MAP") and workspace.MAPS["GAME MAP"]:FindFirstChild("Other")
	if not other then
		phaseableCache = {}
		return
	end
	local list = {}
	for _, part in next, other:GetDescendants() do
		if part:IsA("BasePart") then
			table.insert(list, part)
		end
	end
	phaseableCache = list
	lastCacheUpdate = tick()
end
local function getNearestPhaseable(checkParts)
	if tick() - lastCacheUpdate > 5 then
		updatePhaseableCache()
	end
	local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
	if not hrp then
		return nil, math.huge
	end
	local nearest, nearestDist = nil, 10
	for _, part in ipairs(phaseableCache) do
		local lower = part.Name:lower()
		for _, v in ipairs(checkParts) do
			if type(v) == "string" and lower:find(v:lower(), nil, true) then
				local dist = (part.Position - hrp.Position).Magnitude
				if dist < nearestDist then
					nearestDist = dist
					nearest = part
				end
				break
			end
		end
	end
	return nearest, nearestDist
end
