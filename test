local function GetMap()
	local maps = workspace:FindFirstChild("MAPS")
	if not maps then
		return nil
	end
	local gm = maps:FindFirstChild("GAME MAP")
	if gm then
		return gm
	end
	for _, c in ipairs(maps:GetChildren()) do
		if c:IsA("Model") or c:IsA("Folder") then
			return c
		end
	end
end
local function GetKillerModel()
	local pf = workspace:FindFirstChild("PLAYERS")
	local kf = pf and pf:FindFirstChild("KILLER")
	if not kf then
		return nil
	end
	return kf:FindFirstChildOfClass("Model")
end

local function FindNearestSurvivor()
	local vp = Camera.ViewportSize
	local center = Vector2.new(vp.X * 0.5, vp.Y * 0.5)
	local best = nil
	local bestD = S.CamFOV
	local pf = workspace:FindFirstChild("PLAYERS")
	local af = pf and pf:FindFirstChild("ALIVE")
	if not af then
		return nil
	end
	for _, m in ipairs(af:GetChildren()) do
		if m.Name == LP.Name then
			continue
		end
		local h = m:FindFirstChild("HumanoidRootPart")
		if not h then
			continue
		end
		local sp, vis = Camera:WorldToViewportPoint(h.Position)
		if not vis then
			continue
		end
		local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
		if d < bestD then
			bestD = d
			best = h
		end
	end
	return best
end

local function StartAimbot(target, duration)
	aimbotActive = true
	S.AimbotTarget = target
	if duration then
		-- for taser linger
		aimbotLingerEnd = tick() + duration
	end
end
local function StopAimbot()
	aimbotActive = false
	S.AimbotTarget = nil
	aimbotLingerEnd = 0
end

-- Hook killer animations
local hookedKillers = {}
local function HookKillerAnim(km)
	if not km or hookedKillers[km] then
		return
	end
	hookedKillers[km] = true
	local hum = km:FindFirstChildOfClass("Humanoid")
	if not hum then
		return
	end
	hum.AnimationPlayed:Connect(function(track)
		if not track or not track.Animation then
			return
		end
		local animId = track.Animation.AnimationId
		local cfg = AIMBOT_ANIM_CONFIG[animId]
		if not cfg then
			return
		end
		if not S[cfg.feature] then
			return
		end
		if cfg.isStop then
			StopAimbot()
			return
		end
		local target = FindNearestSurvivor()
		if not target then
			return
		end
		-- Start aimbot instantly
		StartAimbot(target)
		-- For taser, add 1 second linger after animation ends
		if cfg.feature == "AimbotTaser" then
			track.Stopped:Connect(function()
				aimbotLingerEnd = tick() + 1
			end)
		else
			track.Stopped:Connect(function()
				StopAimbot()
			end)
		end
	end)
	km.AncestryChanged:Connect(function()
		if not km.Parent then
			hookedKillers[km] = nil
		end
	end)
end
