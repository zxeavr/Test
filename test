local parryConn = nil
local function SetAutoParry(on)
	if parryConn then
		parryConn:Disconnect()
		parryConn = nil
	end
	if not on then
		return
	end
	parryConn = RunService.Heartbeat:Connect(function()
		if not S.AutoParry then
			return
		end
		local char = LP.Character
		if not char then
			return
		end
		local myRoot = char:FindFirstChild("HumanoidRootPart")
		if not myRoot then
			return
		end
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr == LP then
				continue
			end
			local pc = plr.Character
			if not pc then
				continue
			end
			local ar = pc:FindFirstChild("HumanoidRootPart")
			if not ar then
				continue
			end
			local distSq = (ar.Position - myRoot.Position):Dot(ar.Position - myRoot.Position)
			if distSq > (S.ParryRangePull * S.ParryRangePull) then
				continue
			end
			local hum = pc:FindFirstChildOfClass("Humanoid")
			if not hum then
				continue
			end
			local anim = hum:FindFirstChildOfClass("Animator")
			if not anim then
				continue
			end
			for _, track in ipairs(anim:GetPlayingAnimationTracks()) do
				if not track.IsPlaying or not track.Animation then
					continue
				end
				local aType = ATTACK_ANIM_IDS[track.Animation.AnimationId]
				if not aType then
					continue
				end
				local rng = (aType == "pull") and S.ParryRangePull or S.ParryRangeBasic
				if distSq > (rng * rng) then
					continue
				end
				DoParry()
				break
			end
		end
	end)
end

