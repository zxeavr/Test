-- SILENT AIM TASER
local clientMousePosRequest = nil
local taseHooked = false
local function FindClientMouseRequest()
	if not getgc then
		return nil
	end
	local ok2, gc = pcall(getgc, true)
	if not ok2 or not gc then
		return nil
	end
	local clientScript = LP.PlayerScripts:FindFirstChild("Client")
	if not clientScript then
		return nil
	end
	for _, f in ipairs(gc) do
		if type(f) ~= "function" then
			continue
		end
		local okE, env = pcall(getfenv, f)
		if not okE or not env then
			continue
		end
		if env.script ~= clientScript then
			continue
		end
		local okC, c1 = pcall(debug.getconstant, f, 1)
		if not okC or type(c1) ~= "string" then
			continue
		end
		if c1:lower() == "mouse" then
			return f
		end
	end
end
local function SetSilentTase(on)
	S.SilentTase = on
	if not on then
		if taseHooked and clientMousePosRequest then
			pcall(function()
				restorefunction(clientMousePosRequest)
			end)
			taseHooked = false
		end
		return
	end
	if not hookfunction then
		print("[PH SilentTase] hookfunction not available")
		return
	end
	if not clientMousePosRequest then
		clientMousePosRequest = FindClientMouseRequest()
	end
	if not clientMousePosRequest then
		print("[PH SilentTase] Mouse function not found")
		return
	end
	pcall(function()
		local origFn = clientMousePosRequest
		hookfunction(clientMousePosRequest, function(...)
			local args = { ... }
			if args[1] == "Mouse" then
				local kf = workspace:FindFirstChild("PLAYERS") and workspace.PLAYERS:FindFirstChild("KILLER")
				if kf then
					local km = kf:GetChildren()[1]
					if km then
						local hrp = km:FindFirstChild("HumanoidRootPart")
						if hrp then
							return hrp.Position
						end
					end
				end
			end
			return origFn(...)
		end)
		taseHooked = true
	end)
end

