-- AUTO FARM with TP/Tween, underground, speed
local farmThread = nil
local function SafeTeleportTo(cf, method)
	if not LPChar then
		return
	end
	local hrp = LPChar:FindFirstChild("HumanoidRootPart")
	if not hrp then
		return
	end
	if method == "Tween" then
		local ti = TweenInfo.new(1 / math.max(S.FarmSpeed, 0.1), Enum.EasingStyle.Quad)
		local goal = { CFrame = cf }
		local tween = TweenService:Create(hrp, ti, goal)
		tween:Play()
		tween.Completed:Wait()
	else
		-- TP instant
		hrp.CFrame = cf
	end
end
local function CompleteAllGenerators()
	local mF = GetMap()
	if not mF then
		return
	end
	local genFolder = mF:FindFirstChild("Generators")
	if not genFolder then
		return
	end
	local wasInstantGen = S.InstantGen
	S.InstantGen = true
	StartInstantGen()
	local underground = S.FarmUnderground
	local yOffset = underground and -200 or 0
	for _, gen in ipairs(genFolder:GetChildren()) do
		if not S.AutoFarm then
			break
		end
		if (gen:GetAttribute("Progress") or 0) >= 100 then
			continue
		end
		if not gen:IsA("Model") or not gen.PrimaryPart then
			continue
		end
		-- Move underground or normal
		local targetPos = gen.PrimaryPart.Position + Vector3.new(0, yOffset, 0)
		SafeTeleportTo(CFrame.new(targetPos), S.FarmMethod)
		task.wait(0.3)
		if underground then
			-- teleport up to gen
			local upPos = gen.PrimaryPart.Position + Vector3.new(0, 2, 0)
			SafeTeleportTo(CFrame.new(upPos), "TP")  -- instant up
			task.wait(0.2)
		end
		local rootPart = gen:FindFirstChild("RootPart")
		if rootPart then
			local attempts = 0
			repeat
				attempts = attempts + 1
				local prompt = nil
				for i = 1, 3 do
					local pt = rootPart:FindFirstChild("Point" .. i)
					if pt then
						local pp = pt:FindFirstChildOfClass("ProximityPrompt")
						if pp and pp.Enabled then
							prompt = pp
							break
						end
					end
				end
				if not prompt then
					for _, atch in ipairs(rootPart:GetChildren()) do
						if atch:IsA("Attachment") then
							local pp = atch:FindFirstChildOfClass("ProximityPrompt")
							if pp and pp.Enabled then
								prompt = pp
								break
							end
						end
					end
				end
				if prompt and fireproximityprompt then
					pcall(function()
						fireproximityprompt(prompt)
					end)
				end
				task.wait(1)
			until (gen:GetAttribute("Progress") or 0) >= 100 or attempts > 15 or not S.AutoFarm
		end
		task.wait(0.3)
		if underground and LPChar then
			-- go back underground
			SafeTeleportTo(CFrame.new(gen.PrimaryPart.Position + Vector3.new(0, -200, 0)), "TP")
			task.wait(0.3)
		end
	end
	if not wasInstantGen then
		S.InstantGen = false
		StopInstantGen()
	end
	-- If underground, wait for escape then exit
	if underground then
		repeat
			task.wait(0.5)
			local gF = workspace:FindFirstChild("GAME")
			local cE = gF and gF:FindFirstChild("CAN_ESCAPE")
		until not S.AutoFarm or (cE and cE.Value)
		EscapeMap()
	end
end
local function SetAutoFarm(on)
	if farmThread then
		pcall(task.cancel, farmThread)
		farmThread = nil
	end
	if not on then
		return
	end
	farmThread = task.spawn(function()
		while S.AutoFarm do
			task.wait(0.5)
			pcall(CompleteAllGenerators)
			task.wait(5)
		end
	end)
end

-- AUTO SWING (improved with Warp priority and debug)
local swingConn = nil
local lastSwing = 0
local m1Btn = nil
local function FindAttackButton()
	if m1Btn and m1Btn.Parent then
		return m1Btn
	end
	m1Btn = nil
	local vp = Camera.ViewportSize
	local cx, cy = vp.X * 0.5, vp.Y * 0.7
	for _, gui in ipairs(LP.PlayerGui:GetChildren()) do
		if not gui:IsA("ScreenGui") or not gui.Enabled then
			continue
		end
		if gui.Name:find("PH_") then
			continue
		end
		for _, desc in ipairs(gui:GetDescendants()) do
			if desc:IsA("ImageButton") or desc:IsA("TextButton") then
				local n = desc.Name:lower()
				if n:find("m1") or n:find("attack") or n:find("punch") or n:find("hit") then
					m1Btn = desc
					return desc
				end
				if desc.AbsoluteSize.X > 20 and desc.AbsoluteSize.Y > 20 then
					local pos = desc.AbsolutePosition + desc.AbsoluteSize * 0.5
					if ((pos.X - cx) ^ 2 + (pos.Y - cy) ^ 2) ^ 0.5 < 120 then
						m1Btn = desc
						return desc
					end
				end
			end
		end
	end
end
local function ExecuteSwing()
	-- Use Warp input first
	FireInput(true, { "M1" })
	-- Fallback: simulate button
	pcall(function()
		local btn = FindAttackButton()
		if btn then
			local pos = btn.AbsolutePosition + btn.AbsoluteSize * 0.5
			if firetouch then
				pcall(function()
					firetouch(btn)
				end)
			else
				VirtualUser:Button1Down(pos, Camera.CFrame)
				task.wait(0.04)
				VirtualUser:Button1Up(pos, Camera.CFrame)
			end
		else
			local vp = Camera.ViewportSize
			VirtualUser:Button1Down(Vector2.new(vp.X * 0.5, vp.Y * 0.7), Camera.CFrame)
			task.wait(0.04)
			VirtualUser:Button1Up(Vector2.new(vp.X * 0.5, vp.Y * 0.7), Camera.CFrame)
		end
	end)
	if _G.PH_Debug then
		Debug("M1 attack fired")
	end
end
local parryingPlayers = {}
workspace.DescendantAdded:Connect(function(c)
	if c:IsA("Highlight") and c.Parent then
		parryingPlayers[c.Parent] = tick()
	end
end)
workspace.DescendantRemoving:Connect(function(c)
	if c:IsA("Highlight") and c.Parent then
		parryingPlayers[c.Parent] = nil
	end
end)
local function IsParrying(m)
	local t = parryingPlayers[m]
	if not t then
		return false
	end
	if (tick() - t) > 1.5 then
		parryingPlayers[m] = nil
		return false
	end
	return true
end
local function SetAutoSwing(on)
	if swingConn then
		swingConn:Disconnect()
		swingConn = nil
	end
	if not on then
		m1Btn = nil
		return
	end
	task.spawn(function()
		task.wait(0.5)
		FindAttackButton()
	end)
	swingConn = RunService.Heartbeat:Connect(function()
		if not S.AutoSwing or (tick() - lastSwing) < 0.42 then
			return
		end
		local char = LP.Character
		local myRoot = char and char:FindFirstChild("HumanoidRootPart")
		if not myRoot then
			return
		end
		pcall(function()
			local pf = workspace:FindFirstChild("PLAYERS")
			local af = pf and pf:FindFirstChild("ALIVE")
			if not af then
				return
			end
			local bd = S.SwingRange + 1
			local bt = nil
			for _, m in ipairs(af:GetChildren()) do
				if m.Name == LP.Name or IsParrying(m) then
					continue
				end
				local h = m:FindFirstChild("HumanoidRootPart")
				if not h then
					continue
				end
				local d = (myRoot.Position - h.Position).Magnitude
				if d < bd then
					bd = d
					bt = m
				end
			end
			if not bt then
				return
			end
			lastSwing = tick()
			ExecuteSwing()
		end)
	end)
end

