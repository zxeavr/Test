-- ANTI TRAP (instant escape + health protection)
local TRAP_ATTRS = { "Trapped", "BeartrapCaught", "Caught", "InTrap", "Tripped", "Snared", "TrapCaught" }
local TRAP_TAGS = { "Trapped", "BeartrapCaught", "Bear", "InBearTrap", "BearTrap" }
local antiTrapConn = nil
local trapSignalConns = {}
local trapDeb = false
local function TrapEscape()
	if not LPChar then
		return
	end
	-- Remove constraints
	local hrp = LPChar:FindFirstChild("HumanoidRootPart")
	if hrp then
		for _, o in ipairs(hrp:GetChildren()) do
			if o:IsA("BallSocketConstraint") or o:IsA("RopeConstraint") or o:IsA("WeldConstraint") then
				pcall(function()
					o:Destroy()
				end)
			end
		end
	end
	-- Clear tags/attrs
	for _, t in ipairs(TRAP_TAGS) do
		pcall(function()
			if CollectionService:HasTag(LPChar, t) then
				CollectionService:RemoveTag(LPChar, t)
			end
		end)
	end
	for _, a in ipairs(TRAP_ATTRS) do
		pcall(function()
			local v = LPChar:GetAttribute(a)
			if type(v) == "boolean" and v then
				LPChar:SetAttribute(a, false)
			elseif type(v) == "number" and v > 0 then
				LPChar:SetAttribute(a, 0)
			end
		end)
	end
	if LPHum and LPHum.WalkSpeed <= 0 then
		LPHum.WalkSpeed = math.max(S.RunSpeed, 16)
	end
	-- Fire escape input (if any)
	FireInput(true, { "Interact" })
	-- Anti-health drain: force health to max (optional, careful)
	if LPHum then
		local maxHp = LPHum.MaxHealth
		if LPHum.Health < maxHp then
			-- only heal if trap might reduce health? Might interfere with real damage.
			-- We'll set it when we detect trap and health decreasing rapidly.
			-- We'll do a quick check later.
		end
	end
	-- Teleport slightly upward to break free
	if hrp and not trapDeb then
		trapDeb = true
		pcall(function()
			hrp.CFrame = hrp.CFrame * CFrame.new(0, 2, 0)
		end)
		task.delay(0.5, function()
			trapDeb = false
		end)
	end
end
local function SetAntiTrap(on)
	if antiTrapConn then
		antiTrapConn:Disconnect()
		antiTrapConn = nil
	end
	for _, c in ipairs(trapSignalConns) do
		pcall(function()
			c:Disconnect()
		end)
	end
	trapSignalConns = {}
	if not on then
		return
	end
	Debug("Anti Trap active")
	for _, tagName in ipairs(TRAP_TAGS) do
		local ok, c = pcall(function()
			return CollectionService:GetInstanceAddedSignal(tagName):Connect(function(inst)
				if not S.AntiTrap then
					return
				end
				if inst == LP.Character or (LP.Character and inst:IsDescendantOf(LP.Character)) then
					TrapEscape()
				end
			end)
		end)
		if ok then
			table.insert(trapSignalConns, c)
		end
	end
	antiTrapConn = RunService.Heartbeat:Connect(function()
		if not S.AntiTrap or not LPChar or not LPHum then
			return
		end
		pcall(function()
			for _, t in ipairs(TRAP_TAGS) do
				if CollectionService:HasTag(LPChar, t) then
					CollectionService:RemoveTag(LPChar, t)
					TrapEscape()
				end
			end
			for _, a in ipairs(TRAP_ATTRS) do
				local v = LPChar:GetAttribute(a)
				if type(v) == "boolean" and v then
					LPChar:SetAttribute(a, false)
					TrapEscape()
				elseif type(v) == "number" and v > 0 then
					LPChar:SetAttribute(a, 0)
					TrapEscape()
				end
			end
			local hrp = LPChar:FindFirstChild("HumanoidRootPart")
			if hrp then
				for _, o in ipairs(hrp:GetChildren()) do
					if o:IsA("BallSocketConstraint") or o:IsA("RopeConstraint") then
						pcall(function()
							o:Destroy()
						end)
						TrapEscape()
					end
				end
			end
			if LPHum.WalkSpeed <= 0 then
				LPHum.WalkSpeed = math.max(S.RunSpeed, 16)
				TrapEscape()
			end
		end)
	end)
	-- Health protect: if trapped and health drops, set it back to max
	task.spawn(function()
		while S.AntiTrap and LPChar and LPHum do
			task.wait(0.1)
			pcall(function()
				local trapped = false
				for _, t in ipairs(TRAP_TAGS) do
					if CollectionService:HasTag(LPChar, t) then
						trapped = true
						break
					end
				end
				if trapped and LPHum.Health < LPHum.MaxHealth then
					LPHum.Health = LPHum.MaxHealth
				end
			end)
		end
	end)
end

