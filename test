-- DELETE DOOR (improved: passable + invisible, reversible)
local doorOrigStates = {}
local doorConn = nil
local function SetDeleteDoor(on)
	if doorConn then
		doorConn:Disconnect()
		doorConn = nil
	end
	local function processDoors(enabled)
		pcall(function()
			local mF = GetMap()
			if not mF then
				return
			end
			local dF = mF:FindFirstChild("Doors")
			if not dF then
				return
			end
			for _, door in ipairs(dF:GetDescendants()) do
				if door:IsA("BasePart") then
					if enabled then
						-- Store original state before modifying
						if not doorOrigStates[door] then
							doorOrigStates[door] = {
								CanCollide = door.CanCollide,
								Transparency = door.Transparency,
							}
						end
						door.CanCollide = false
						door.CanTouch = false
						door.Transparency = 1
					else
						if doorOrigStates[door] then
							door.CanCollide = doorOrigStates[door].CanCollide
							door.Transparency = doorOrigStates[door].Transparency
							doorOrigStates[door] = nil
						end
					end
				end
			end
		end)
	end
	if on then
		processDoors(true)
		doorConn = workspace.DescendantAdded:Connect(function(d)
			if not S.DeleteDoor or not d:IsA("BasePart") then
				return
			end
			pcall(function()
				local mF = GetMap()
				if not mF then
					return
				end
				local dF = mF:FindFirstChild("Doors")
				if dF and d:IsDescendantOf(dF) then
					doorOrigStates[d] = { CanCollide = d.CanCollide, Transparency = d.Transparency }
					d.CanCollide = false
					d.CanTouch = false
					d.Transparency = 1
				end
			end)
		end)
	else
		processDoors(false)
	end
end

